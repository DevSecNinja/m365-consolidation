{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start local server",
      "type": "shell",
      "command": "python3 -m http.server 8080 --bind 0.0.0.0",
      "isBackground": true,
      "hide": true,
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "never",
        "panel": "dedicated",
        "clear": false
      },
      "problemMatcher": {
        "owner": "python-http-server",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Serving HTTP on .* port 8080"
        }
      }
    },
    {
      "label": "Open local site",
      "type": "shell",
      "command": "\"$BROWSER\" http://localhost:8080",
      "dependsOn": "Start local server",
      "dependsOrder": "sequence",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "never",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    }
  ]
}